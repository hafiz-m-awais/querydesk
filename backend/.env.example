# QueryDesk v3 Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# ─── Database ─────────────────────────────────────────────
# PostgreSQL connection string (Supabase / Neon / local)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/querydesk

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
# Access token TTL in minutes
JWT_ACCESS_EXPIRE_MINUTES=480

# ─── OTP ──────────────────────────────────────────────────
OTP_TTL_MINUTES=10
OTP_LENGTH=6
# Optional: set a random secret to HMAC-SHA256-hash OTPs at rest
OTP_HMAC_SECRET=

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_OTP_PER_MINUTE=5
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_SUBMIT_PER_MINUTE=20

# ─── Email (SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# ─── App ──────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=https://hafiz-m-awais.github.io,http://localhost:5500
APP_ENV=development
